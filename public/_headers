# Cache versioned static files for 1 year (immutable)
# These files have ?v=timestamp in URL, so they change when content changes
/static/app.min.js
  Cache-Control: public, max-age=31536000, immutable
/static/gamification.js
  Cache-Control: public, max-age=31536000, immutable
/static/style.css
  Cache-Control: public, max-age=31536000, immutable

