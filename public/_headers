# Security headers - Allow TossPayments SDK and CDN resources
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://js.tosspayments.com https://cdn.tailwindcss.com https://cdn.jsdelivr.net https://accounts.google.com; style-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://cdn.jsdelivr.net; img-src 'self' data: https:; connect-src 'self' https://api.tosspayments.com; frame-src https://accounts.google.com; font-src 'self' data:; media-src 'self' blob: data:

# No cache for HTML pages - always fetch fresh
/app
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

/landing
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

/
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# Short cache for static files WITH version query params
# When ?v=timestamp changes, browser fetches new file
/static/app.min.js
  Cache-Control: public, max-age=3600, must-revalidate
/static/app.js
  Cache-Control: public, max-age=3600, must-revalidate
/static/gamification.js
  Cache-Control: public, max-age=3600, must-revalidate
/static/style.css
  Cache-Control: public, max-age=3600, must-revalidate
/static/toast.js
  Cache-Control: public, max-age=3600, must-revalidate
/static/error-handler.js
  Cache-Control: public, max-age=3600, must-revalidate

# Long cache for images (rarely change)
/static/*.webp
  Cache-Control: public, max-age=86400
/static/*.png
  Cache-Control: public, max-age=86400
/static/*.jpg
  Cache-Control: public, max-age=86400

