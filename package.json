{
  "name": "webapp",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --d1=webapp-production --local --ip 0.0.0.0 --port 3000",
    "prebuild": "node update-build-time.cjs && node build-static.js",
    "build": "vite build && node postbuild.js",
    "build:static": "node build-static.js",
    "minify": "npx terser public/static/app.js -o public/static/app.min.js --compress --mangle",
    "minify:scenario": "npx terser public/static/scenario-data.js -o public/static/scenario-data.min.js --compress --mangle",
    "minify:all": "npm run minify && npm run minify:scenario",
    "preview": "wrangler pages dev",
    "deploy": "npm run build && wrangler pages deploy dist",
    "deploy:prod": "npm run build && wrangler pages deploy dist --project-name webapp",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply webapp-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply webapp-production",
    "db:console:local": "wrangler d1 execute webapp-production --local",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "test": "curl http://localhost:3000"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "hono": "^4.11.9",
    "openai": "^6.25.0"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "terser": "^5.46.1",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
